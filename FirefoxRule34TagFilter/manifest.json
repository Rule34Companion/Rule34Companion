{
    "manifest_version": 3,
    "name": "Rule34Companion Tag Filter",
    "version": "2.0",
    "description": "Client-side tag filtering without the 100 tag limit, with image ID blacklist.",
    "permissions": [ "storage", "nativeMessaging", "tabs" ],
    "host_permissions": [ "https://rule34.xxx/*" ],
    "browser_specific_settings": {
        "gecko": {
            "id": "Rule34TagFilter@Rule34Companion.com",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [ "none" ]
            }
        }
    },
    "content_scripts": [
        {
            "matches": [ "https://rule34.xxx/*" ],
            "js": [ "content.js" ],
            "css": [ "content.css" ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "scripts": [ "background.js" ]
    },
    "action": {
        "default_popup": "popup.html"
    }
}
